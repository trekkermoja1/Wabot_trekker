{
  "name": "knightbot",
  "version": "1.0.0",
  "description": "WhatsApp Bot",
  "main": "index.js",
  "scripts": {
    "start": "npm install && pip install -r backend/requirements.txt && cd frontend && npm install --legacy-peer-deps && npm run build && cd .. && mkdir -p backend/static && cp -r frontend/build/* backend/static/ && cd bot && npm install && cd .. && cd backend && python server.py",
    "start:backend": "pip install python-dotenv uvicorn fastapi httpx pydantic asyncpg motor && cd backend && python server.py",
    "build:frontend": "cd frontend && ([ -d node_modules ] || npm install --legacy-peer-deps) && npm run build && mkdir -p ../backend/static && cp -r build/* ../backend/static/ && cd ../bot && ([ -d node_modules ] || npm install)",
    "stop": "pkill -f 'python server.py' || true",
    "start:bot": "node index.js",
    "start:optimized": "node --max-old-space-size=512 --optimize-for-size --gc-interval=100 index.js",
    "cleanup": "node cleanup.js",
    "reset-session": "node reset-session.js",
    "start:clean": "npm run cleanup && npm run start:optimized",
    "start:fresh": "npm run reset-session && npm start:bot",
    "install:panel": "npm install --legacy-peer-deps",
    "install:force": "npm install --force",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docker:build": "docker build -t knightbot . && docker run -e SESSION_ID=$SESSION_ID knightbot",
    "prestart": "npm install && cd frontend && ([ -d node_modules ] || npm install) && cd ../bot && ([ -d node_modules ] || npm install)"
  },
  "keywords": [
    "whatsapp-bot"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@distube/ytdl-core": "^4.16.12",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@hapi/boom": "^10.0.1",
    "@types/node": "^18.0.6",
    "@whiskeysockets/baileys": "^v7.0.0-rc.9",
    "awesome-phonenumber": "^5.9.0",
    "axios": "^1.13.2",
    "chalk": "^4.1.2",
    "cheerio": "^1.1.2",
    "cookie": "^0.5.0",
    "dotenv": "^16.4.5",
    "entities": "^4.5.0",
    "events": "^3.3.0",
    "file-type": "^16.5.4",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "fs-extra": "^11.2.0",
    "gtts": "^0.2.1",
    "human-readable": "^0.2.1",
    "jimp": "^1.6.0",
    "jsdom": "^22.1.0",
    "libphonenumber-js": "^1.11.18",
    "libsignal": "^2.0.1",
    "libsignal-node": "^2.0.1",
    "link-preview-js": "^3.2.0",
    "long": "^5.3.2",
    "moment-timezone": "^0.5.48",
    "mumaker": "^2.0.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "node-id3": "^0.2.3",
    "node-webpmux": "^3.2.1",
    "node-youtube-music": "^0.8.3",
    "performance-now": "^2.1.0",
    "phin": "^3.7.1",
    "pino": "^8.21.0",
    "qrcode": "^1.5.4",
    "qrcode-reader": "^1.0.4",
    "qrcode-terminal": "^0.12.0",
    "request": "^2.88.2",
    "ruhend-scraper": "^8.3.0",
    "safe-stable-stringify": "^2.5.0",
    "set-cookie": "^0.0.4",
    "sharp": "^0.32.6",
    "tough-cookie": "^5.1.2",
    "translate-google-api": "^1.0.4",
    "ws": "^8.19.0",
    "yargs": "^17.7.2",
    "yargs-parser": "^21.1.1",
    "youtube-yts": "^2.0.0",
    "youtubedl-core": "^4.11.7",
    "yt-search": "^2.13.1",
    "ytdl-core": "^4.11.5"
  },
  "overrides": {
